generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model UserProfile {
  id                 String   @id @default(cuid())
  fullName           String
  email              String   @unique
  phoneNumber        String?
  location           String?
  
  expectedSalary     String?
  workAuthorization  String?
  noticePeriod       String?
  linkedInUrl        String?
  githubUrl          String?
  
  // Stored as JSON string since SQLite doesn't natively support JSON arrays perfectly
  skills             String? 
  experience         String? 
  education          String? 
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model JobListing {
  id               String   @id @default(cuid())
  company          String
  role             String
  jobDescription   String
  matchScore       Int?
  status           String   @default("NEW") // NEW, APPLIED, SKIPPED, FAILED
  url              String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ApplicationLog {
  id               String   @id @default(cuid())
  jobId            String
  status           String
  errorMessage     String?
  
  createdAt        DateTime @default(now())
}
